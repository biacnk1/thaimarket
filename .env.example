# Copy these names into Vercel Project Settings > Environment Variables.
# Keep real values in .env.local or Vercel only; do not commit secrets.
APP_DATA_MODE=supabase
NEXT_PUBLIC_APP_DATA_MODE=supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret. Do not expose this to the browser.
# Required for predictions and admin resolution.
SUPABASE_SERVICE_ROLE_KEY=

# Optional fallback for server-side admin checks when app_metadata.role is not set.
ADMIN_EMAILS=
